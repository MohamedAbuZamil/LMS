# Server
NODE_ENV=development
PORT=8080
HOST=0.0.0.0

# Database (Azure PostgreSQL Flexible Server)
DATABASE_URL="postgresql://lmsadmin:YOUR_PASSWORD@lmszamil-db.postgres.database.azure.com:5432/lms?sslmode=require"

# CORS — frontends allowed to call this API (comma-separated)
CORS_ORIGINS="http://localhost:3000,https://lmszamil.azurewebsites.net,https://lmszamil-teacher.azurewebsites.net,https://lmszamil-admin.azurewebsites.net"

# Auth — JWT signing secret (generate a long random string for production)
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS=30
